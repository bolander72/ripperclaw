---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav'
import Footer from '../components/Footer'
import { 
  IconWorldSearch, IconFingerprint, IconCopy, 
  IconPuzzle, IconUserCircle, IconRefresh 
} from '@tabler/icons-react'

const features = [
  {
    icon: IconWorldSearch,
    title: 'Cross-platform search',
    desc: 'Find kits from GitHub, ClawHub, skills.sh, and more. One search, every source. Works with Claude Code, Cursor, OpenClaw, and 30+ agents.',
  },
  {
    icon: IconFingerprint,
    title: 'Universal standard',
    desc: 'Built on Agent Skills (agentskills.io) — the open format created by Anthropic and adopted by 30+ agents. Kits work everywhere.',
  },
  {
    icon: IconCopy,
    title: 'Add, not configure',
    desc: "Find a kit you like? Add it with one CLI command, download the JSON, or grab it from GitHub. Give it to your agent — it'll know what to do.",
  },
  {
    icon: IconPuzzle,
    title: 'Complete kits',
    desc: 'Every kit is a collection of skills, configs, and conventions. From personal assistants to DevOps automation to marketing stacks.',
  },
  {
    icon: IconUserCircle,
    title: 'Community-driven',
    desc: 'Verified kits from official sources (Anthropic, Microsoft) and community kits from developers worldwide. Trust tiers and stars help you decide.',
  },
  {
    icon: IconRefresh,
    title: 'Remix and combine',
    desc: 'Pull skills from different kits into your own. Combine a voice assistant with smart home control. Add what you need, ignore the rest.',
  },
]

const steps = [
  { num: '01', title: 'Search', desc: 'Find kits by capability, use case, agent compatibility, or tags. Filter by which agent you use — Claude Code, Cursor, OpenClaw, etc.' },
  { num: '02', title: 'Explore', desc: 'See exactly what skills are in a kit. Check compatibility, read descriptions, view the source repo, see GitHub stars and trust tier.' },
  { num: '03', title: 'Add', desc: 'Download the JSON, copy the CLI command, or view on GitHub. Give it to your AI agent and it handles the rest. No manual setup.' },
]
---

<BaseLayout title="About - ClawClawGo" description="ClawClawGo is the agent kits search engine. Find curated skill collections for Claude Code, Cursor, OpenClaw, and 30+ AI agents.">
  <div class="min-h-screen bg-rc-bg">
    <Nav client:load />
    
    <main class="max-w-6xl mx-auto px-6">
      {/* What is it */}
      <section class="py-16">
        <div class="text-center mb-16">
          <h1 class="text-3xl md:text-4xl font-grotesk font-bold text-rc-text mb-4">
            About ClawClawGo
          </h1>
          <p class="text-rc-text-dim text-lg max-w-2xl mx-auto">
            The agent kits search engine. Find curated skill collections for your AI agent.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {features.map((f, i) => (
            <div 
              class="p-6 rounded-2xl bg-rc-surface border border-rc-border hover:border-rc-cyan/30 transition-colors group"
              style={`animation: fadeInUp 0.5s ease-out ${i * 0.08}s both`}
            >
              <div class="w-10 h-10 rounded-xl bg-rc-cyan/10 flex items-center justify-center mb-4 group-hover:bg-rc-cyan/20 transition-colors">
                <f.icon size={20} className="text-rc-cyan" stroke={1.5} />
              </div>
              <h3 class="font-grotesk font-semibold text-rc-text text-base mb-2">{f.title}</h3>
              <p class="text-rc-text-dim text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      {/* How it works */}
      <section class="py-16 relative">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-rc-cyan/3 rounded-full blur-[150px] pointer-events-none" />
        <div class="max-w-4xl mx-auto relative z-10">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-grotesk font-bold text-rc-text mb-4">
              How it works
            </h2>
            <p class="text-rc-text-dim text-lg max-w-xl mx-auto">
              Search for kits. Explore what's inside. Add to your agent.
            </p>
          </div>
          <div class="space-y-8">
            {steps.map((step, i) => (
              <div 
                class="flex gap-6 items-start"
                style={`animation: fadeInLeft 0.5s ease-out ${i * 0.15}s both`}
              >
                <div class="shrink-0 w-12 h-12 rounded-2xl bg-rc-cyan/10 border border-rc-cyan/20 flex items-center justify-center">
                  <span class="text-rc-cyan font-mono font-bold text-sm">{step.num}</span>
                </div>
                <div class="flex-1">
                  <h3 class="font-grotesk font-bold text-rc-text text-xl mb-2">{step.title}</h3>
                  <p class="text-rc-text-dim text-sm leading-relaxed">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>
    
    <Footer client:load />
  </div>
</BaseLayout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
