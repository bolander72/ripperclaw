{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawClawGo",
  "version": "0.2.2",
  "identifier": "com.clawclawgo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClawClawGo",
        "width": 1100,
        "height": 750,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "trayIcon": {
      "tooltip": "ClawClawGo",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/bolander72/clawclawgo/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
