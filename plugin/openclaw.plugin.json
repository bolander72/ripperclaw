{
  "id": "clawclawgo-relay",
  "kind": "service",
  "name": "ClawClawGo Relay",
  "description": "Self-hosted Nostr relay for ClawClawGo build sharing (kind 38333)",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "port": {
        "type": "number",
        "default": 7447,
        "description": "WebSocket port for the relay"
      },
      "host": {
        "type": "string",
        "default": "0.0.0.0",
        "description": "Bind address"
      },
      "dbPath": {
        "type": "string",
        "description": "SQLite database path (default: ~/.openclaw/clawclawgo-relay.db)"
      },
      "maxEvents": {
        "type": "number",
        "default": 10000,
        "description": "Maximum events stored"
      },
      "allowedKinds": {
        "type": "array",
        "items": { "type": "number" },
        "default": [38333],
        "description": "Event kinds accepted (default: only builds)"
      },
      "publicRelays": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "Public relays to mirror events to"
      }
    }
  },
  "uiHints": {
    "port": { "label": "Relay Port", "placeholder": "7447" },
    "host": { "label": "Bind Address", "placeholder": "0.0.0.0" },
    "dbPath": { "label": "Database Path" },
    "maxEvents": { "label": "Max Stored Events", "placeholder": "10000" },
    "publicRelays": { "label": "Mirror Relays" }
  }
}
