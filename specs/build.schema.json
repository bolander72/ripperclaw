{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://clawclawgo.com/schemas/build-v3.json",
  "title": "Clawclawgo Build v3",
  "description": "Canonical format for OpenClaw agent builds: export, share, and apply.",
  "type": "object",
  "required": ["schema", "meta"],
  "properties": {
    "schema": {
      "const": 3,
      "description": "Schema version. Must be 3."
    },
    "meta": {
      "type": "object",
      "required": ["name", "agentName", "author", "version", "exportedAt"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name for this build"
        },
        "agentName": {
          "type": "string",
          "description": "Name of the agent this was exported from"
        },
        "description": {
          "type": "string",
          "description": "One-liner about what this agent does"
        },
        "author": {
          "type": "string",
          "description": "Creator handle (e.g., @Bolander72)"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Build revision number, bumps on re-export"
        },
        "exportedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of export"
        },
        "openclawVersion": {
          "type": "string",
          "description": "OpenClaw version at export time"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Searchable tags"
        }
      }
    },
    "model": { "$ref": "#/definitions/modelConfig" },
    "persona": { "$ref": "#/definitions/personaConfig" },
    "skills": { "$ref": "#/definitions/skillsConfig" },
    "integrations": { "$ref": "#/definitions/integrationsConfig" },
    "automations": { "$ref": "#/definitions/automationsConfig" },
    "memory": { "$ref": "#/definitions/memoryConfig" },
    "dependencies": { "$ref": "#/definitions/dependenciesConfig" }
  },
  "definitions": {
    "modelTier": {
      "type": "object",
      "required": ["provider", "model"],
      "properties": {
        "provider": {
          "type": "string",
          "description": "Provider name (anthropic, openai, ollama, google, etc.)"
        },
        "model": {
          "type": "string",
          "description": "Full model identifier"
        },
        "alias": {
          "type": "string",
          "description": "Human-friendly name (e.g., Opus, Sonnet)"
        },
        "paid": {
          "type": "boolean",
          "description": "Whether this model requires a paid API key"
        },
        "local": {
          "type": "boolean",
          "description": "Whether this model runs locally"
        }
      }
    },
    "modelConfig": {
      "type": "object",
      "required": ["tiers"],
      "properties": {
        "tiers": {
          "type": "object",
          "properties": {
            "main": { "$ref": "#/definitions/modelTier" },
            "subagent": { "$ref": "#/definitions/modelTier" },
            "heartbeat": { "$ref": "#/definitions/modelTier" },
            "utility": { "$ref": "#/definitions/modelTier" }
          },
          "additionalProperties": { "$ref": "#/definitions/modelTier" }
        },
        "routing": {
          "type": "object",
          "properties": {
            "description": {
              "type": "string",
              "description": "Human-readable routing strategy"
            }
          }
        }
      }
    },
    "personaConfig": {
      "type": "object",
      "properties": {
        "identity": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "creature": { "type": "string" },
            "vibe": { "type": "string" }
          }
        },
        "soul": {
          "type": "object",
          "properties": {
            "included": { "type": "boolean" },
            "preview": {
              "type": "string",
              "description": "First ~500 chars for preview before applying"
            },
            "content": {
              "type": "string",
              "description": "Full SOUL.md content (PII-scrubbed)"
            },
            "tokenEstimate": { "type": "integer" }
          }
        },
        "user": {
          "type": "object",
          "properties": {
            "included": {
              "const": false,
              "description": "USER.md is never included in shared builds"
            },
            "note": { "type": "string" }
          }
        },
        "agents": {
          "type": "object",
          "properties": {
            "included": { "type": "boolean" },
            "preview": { "type": "string" },
            "content": { "type": "string" }
          }
        }
      }
    },
    "skillItem": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Skill package name"
        },
        "version": {
          "type": "string",
          "description": "Semver version string"
        },
        "source": {
          "type": "string",
          "enum": ["clawhub", "local", "custom", "bundled"],
          "description": "Where this skill comes from"
        },
        "description": {
          "type": "string",
          "description": "What this skill does"
        },
        "requiresConfig": {
          "type": "boolean",
          "description": "Whether post-install configuration is needed"
        },
        "configHint": {
          "type": "string",
          "description": "What configuration is needed"
        }
      }
    },
    "skillsConfig": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/skillItem" }
        }
      }
    },
    "integrationItem": {
      "type": "object",
      "required": ["type", "name", "provider"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["channel", "calendar", "email", "smart-home", "code", "voice", "camera", "other"],
          "description": "Integration category"
        },
        "name": {
          "type": "string",
          "description": "Human-readable integration name"
        },
        "provider": {
          "type": "string",
          "description": "Provider/tool identifier (bluebubbles, caldir, himalaya, etc.)"
        },
        "autoApply": {
          "const": false,
          "description": "Integrations are never auto-applied"
        },
        "docsUrl": {
          "type": "string",
          "format": "uri",
          "description": "Link to setup docs (human-readable)"
        },
        "setupGuideUrl": {
          "type": "string",
          "format": "uri",
          "description": "Machine-readable setup guide URL (fetched by applying agent)"
        }
      }
    },
    "integrationsConfig": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/integrationItem" }
        }
      }
    },
    "cronItem": {
      "type": "object",
      "required": ["name", "schedule"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Cron job display name"
        },
        "schedule": {
          "type": "object",
          "description": "Schedule definition (kind: at | every | cron)",
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["at", "every", "cron"]
            }
          }
        },
        "description": {
          "type": "string",
          "description": "What this automation does"
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dot-path references to required integrations/skills (e.g., integrations.email)"
        }
      }
    },
    "automationsConfig": {
      "type": "object",
      "properties": {
        "heartbeat": {
          "type": "object",
          "properties": {
            "included": { "type": "boolean" },
            "content": {
              "type": "string",
              "description": "HEARTBEAT.md content"
            },
            "taskCount": { "type": "integer" }
          }
        },
        "cron": {
          "type": "array",
          "items": { "$ref": "#/definitions/cronItem" }
        }
      }
    },
    "templateFile": {
      "type": "object",
      "required": ["path", "content"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path within workspace"
        },
        "content": {
          "type": "string",
          "description": "File template content"
        }
      }
    },
    "memoryConfig": {
      "type": "object",
      "properties": {
        "structure": {
          "type": "object",
          "properties": {
            "directories": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Directories to create"
            },
            "templateFiles": {
              "type": "array",
              "items": { "$ref": "#/definitions/templateFile" },
              "description": "Template files to seed (never overwrites existing)"
            }
          }
        },
        "engine": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          },
          "description": "Informational: what memory engine this agent uses"
        }
      }
    },
    "modelRequirement": {
      "type": "object",
      "required": ["name", "url", "path"],
      "properties": {
        "name": { "type": "string", "description": "Model file name" },
        "url": { "type": "string", "format": "uri", "description": "Download URL" },
        "path": { "type": "string", "description": "Install path (supports ~)" },
        "size": { "type": "string", "description": "File size (e.g., '82MB')" }
      }
    },
    "configRequirement": {
      "type": "object",
      "required": ["key"],
      "properties": {
        "key": { "type": "string", "description": "Environment variable or keychain key" },
        "description": { "type": "string", "description": "What this config is for" },
        "required": { "type": "boolean", "description": "Whether this is required" }
      }
    },
    "dependenciesConfig": {
      "type": "object",
      "properties": {
        "bins": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required binaries on PATH"
        },
        "brew": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Homebrew packages"
        },
        "pip": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Python pip packages"
        },
        "npm": {
          "type": "array",
          "items": { "type": "string" },
          "description": "npm global packages"
        },
        "models": {
          "type": "array",
          "items": { "$ref": "#/definitions/modelRequirement" },
          "description": "Model files to download"
        },
        "config": {
          "type": "array",
          "items": { "$ref": "#/definitions/configRequirement" },
          "description": "Configuration requirements"
        },
        "platform": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supported platforms (darwin, linux, win32)"
        },
        "minOpenclawVersion": {
          "type": "string",
          "description": "Minimum OpenClaw version"
        },
        "guides": {
          "type": "object",
          "additionalProperties": { "type": "string", "format": "uri" },
          "description": "Setup guides keyed by provider/tool name (URLs to fetchable markdown)"
        }
      }
    }
  }
}
